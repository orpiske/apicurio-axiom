{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "group:monorepos",
        "group:recommended"
    ],
    "enabledManagers": [
        "maven", "npm"
    ],
    "dependencyDashboard": true,
    "rangeStrategy": "bump",
    "ignorePaths": [
        "ui/node_modules/**"
    ],
    "prConcurrentLimit": 10,
    "prHourlyLimit": 5,
    "packageRules": [
        {
            "description": "Group all major updates into a single monthly PR",
            "matchUpdateTypes": ["major"],
            "groupName": "all major dependencies",
            "schedule": ["on the first day of the month"],
            "labels": ["area/dependencies", "update/major"]
        },
        {
            "description": "Label minor dependency updates",
            "matchUpdateTypes": ["minor"],
            "labels": ["area/dependencies", "update/minor"]
        },
        {
            "description": "Label patch dependency updates",
            "matchUpdateTypes": ["patch"],
            "labels": ["area/dependencies", "update/patch"]
        }
    ]
}
