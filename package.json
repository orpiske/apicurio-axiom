{
    "name": "apicurio-axiom",
    "version": "1.0.8",
    "description": "Event-driven automation system for GitHub and Jira using NATS",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "build": "npm run build --workspaces",
        "clean": "npm run clean --workspaces --if-present && rm -rf data node_modules",
        "dev:nats": "docker compose up nats nats-setup -d && echo 'NATS is running on localhost:4222 (monitoring: http://localhost:8222)'",
        "dev:nats:down": "docker compose stop nats-setup nats && docker compose rm -f nats",
        "dev:nats:logs": "docker compose logs -f nats",
        "dev:github-poller": "npm run dev --workspace=@axiom/github-poller",
        "dev:jira-poller": "npm run dev --workspace=@axiom/jira-poller",
        "dev:event-handler": "npm run dev --workspace=@axiom/event-handler",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "docker:logs": "docker compose logs -f",
        "docker:build": "docker compose up --build -d",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "keywords": [
        "github",
        "bot",
        "automation",
        "events"
    ],
    "author": "Apicurio Community",
    "license": "Apache-2.0",
    "dependencies": {
        "@anthropic-ai/sdk": "0.74.0",
        "@anthropic-ai/vertex-sdk": "0.14.3",
        "@octokit/rest": "22.0.1",
        "ajv": "8.17.1",
        "ajv-formats": "3.0.1",
        "axios": "1.13.5",
        "better-sqlite3": "12.6.2",
        "diff": "^8.0.3",
        "duck-duck-scrape": "2.2.7",
        "fast-glob": "3.3.3",
        "fs-extra": "11.3.3",
        "handlebars": "4.7.8",
        "js-yaml": "4.1.1",
        "node-pty": "1.1.0",
        "pino": "10.3.1",
        "pino-pretty": "13.1.3",
        "validator": "13.15.26"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.14",
        "@types/better-sqlite3": "7.6.13",
        "@types/fs-extra": "11.0.4",
        "@types/js-yaml": "4.0.9",
        "@types/node": "25.2.3",
        "@types/validator": "13.15.10",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "ts-node": "10.9.2",
        "typescript": "5.9.3",
        "vitest": "4.0.18"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
