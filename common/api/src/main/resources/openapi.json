    "components": {
        "parameters": {
            "ProjectId": {
                "name": "projectId",
                "in": "path",
                "required": true,
                "schema": { "type": "integer", "format": "int64" },
                "description": "Project ID"
            },
            "TaskId": {
                "name": "taskId",
                "in": "path",
                "required": true,
                "schema": { "type": "integer", "format": "int64" },
                "description": "Task ID"
            },
            "ActorId": {
                "name": "actorId",
                "in": "path",
                "required": true,
                "schema": { "type": "integer", "format": "int64" },
                "description": "Actor ID"
            },
            "ActionTypeId": {
                "name": "actionTypeId",
                "in": "path",
                "required": true,
                "schema": { "type": "integer", "format": "int64" },
                "description": "Action type ID"
            },
            "PolicyId": {
                "name": "policyId",
                "in": "path",
                "required": true,
                "schema": { "type": "integer", "format": "int64" },
                "description": "Policy ID"
            },
            "RepositoryId": {
                "name": "repositoryId",
                "in": "path",
                "required": true,
                "schema": { "type": "integer", "format": "int64" },
                "description": "Repository ID"
            }
        },

        "responses": {
            "NotFound": {
                "description": "Resource not found",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/Error" }
                    }
                }
            }
        },

        "schemas": {
            "Error": {
                "type": "object",
                "properties": {
                    "message": { "type": "string" },
                    "errorCode": { "type": "integer" }
                }
            },

            "SystemHealth": {
                "type": "object",
                "required": ["status", "version", "timestamp"],
                "properties": {
                    "status": {
                        "type": "string",
                        "enum": ["UP", "DOWN"]
                    },
                    "version": { "type": "string" },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "SystemConfig": {
                "type": "object",
                "properties": {
                    "version": { "type": "string" },
                    "features": { "$ref": "#/components/schemas/Features" }
                }
            },
            "Features": {
                "type": "object",
                "additionalProperties": { "type": "boolean" }
            },

            "Project": {
                "type": "object",
                "required": ["id", "name", "type", "status", "issueSource", "issueRef", "repository", "createdOn", "updatedOn"],
                "properties": {
                    "id": { "type": "integer", "format": "int64" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "type": {
                        "type": "string",
                        "enum": ["bug-fix", "feature", "question", "help", "other"]
                    },
                    "status": {
                        "type": "string",
                        "enum": ["Created", "InProgress", "Idle", "Completed"]
                    },
                    "issueSource": {
                        "type": "string",
                        "enum": ["github", "jira"]
                    },
                    "issueRef": { "type": "string" },
                    "repository": { "type": "string" },
                    "createdOn": { "type": "string", "format": "date-time" },
                    "updatedOn": { "type": "string", "format": "date-time" },
                    "metadata": { "type": "object", "additionalProperties": { "type": "string" } }
                }
            },
            "NewProject": {
                "type": "object",
                "required": ["name", "type", "issueSource", "issueRef", "repository"],
                "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "type": {
                        "type": "string",
                        "enum": ["bug-fix", "feature", "question", "help", "other"]
                    },
                    "issueSource": {
                        "type": "string",
                        "enum": ["github", "jira"]
                    },
                    "issueRef": { "type": "string" },
                    "repository": { "type": "string" },
                    "metadata": { "type": "object", "additionalProperties": { "type": "string" } }
                }
            },
            "UpdateProject": {
                "type": "object",
                "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "type": {
                        "type": "string",
                        "enum": ["bug-fix", "feature", "question", "help", "other"]
                    },
                    "status": {
                        "type": "string",
                        "enum": ["Created", "InProgress", "Idle", "Completed"]
                    },
                    "metadata": { "type": "object", "additionalProperties": { "type": "string" } }
                }
            },

            "Task": {
                "type": "object",
                "required": ["id", "projectId", "actionType", "createdBy", "status", "createdOn"],
                "properties": {
                    "id": { "type": "integer", "format": "int64" },
                    "projectId": { "type": "integer", "format": "int64" },
                    "actionType": { "type": "string" },
                    "createdBy": {
                        "type": "string",
                        "enum": ["manager", "user"]
                    },
                    "assignedActor": { "type": "integer", "format": "int64" },
                    "status": {
                        "type": "string",
                        "enum": ["Pending", "InProgress", "AwaitingInput", "Completed", "Failed", "Cancelled"]
                    },
                    "input": { "type": "string" },
                    "output": { "type": "string" },
                    "createdOn": { "type": "string", "format": "date-time" },
                    "completedOn": { "type": "string", "format": "date-time" }
                }
            },
            "NewTask": {
                "type": "object",
                "required": ["actionType"],
                "properties": {
                    "actionType": { "type": "string" },
                    "assignedActor": { "type": "integer", "format": "int64" },
                    "input": { "type": "string" }
                }
            },

            "Actor": {
                "type": "object",
                "required": ["id", "name", "type"],
                "properties": {
                    "id": { "type": "integer", "format": "int64" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "type": {
                        "type": "string",
                        "enum": ["human", "ai-agent"]
                    },
                    "capabilities": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "permissions": { "type": "object", "additionalProperties": {} },
                    "configuration": { "type": "object", "additionalProperties": {} }
                }
            },
            "NewActor": {
                "type": "object",
                "required": ["name", "type"],
                "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "type": {
                        "type": "string",
                        "enum": ["human", "ai-agent"]
                    },
                    "capabilities": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "permissions": { "type": "object", "additionalProperties": {} },
                    "configuration": { "type": "object", "additionalProperties": {} }
                }
            },

            "ActionType": {
